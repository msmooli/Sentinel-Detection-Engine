{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "workspaceName": {
      "type": "string",
      "metadata": { "description": "Log Analytics workspace name" }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    }
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "apiVersion": "2022-11-01-preview",
      "name": "[concat(parameters('workspaceName'), '/Microsoft.SecurityInsights/rdp-hijacking-t1563002')]",
      "kind": "Scheduled",
      "location": "[parameters('location')]",
      "properties": {

        "displayName": "RDP Session Hijacking via tscon.exe (T1563.002)",

        "description": "Detects use of tscon.exe to hijack an existing RDP session. This lateral movement technique (T1563.002) requires SYSTEM privileges and transfers a session without the victim's credentials — leaving no password event in the log. Look for tscon.exe spawned by cmd.exe or powershell.exe under SYSTEM context. Triage: check what the account did immediately after session transfer, and correlate with logon events on the destination host.",

        "severity": "Medium",

        "status": "Observation",

        "enabled": true,

        "query": "SecurityEvent\n| where EventID == 4688\n| where TimeGenerated > ago(1h)\n| where NewProcessName endswith '\\\\tscon.exe'\n| where SubjectUserName == 'SYSTEM'\n      or ParentProcessName has_any ('cmd.exe', 'powershell.exe', 'pwsh.exe')\n| project\n    TimeGenerated,\n    Computer,\n    SubjectUserName,\n    SubjectDomainName,\n    NewProcessName,\n    CommandLine,\n    ParentProcessName,\n    SubjectLogonId",

        "queryFrequency": "PT5M",
        "queryPeriod": "PT1H",
        "triggerOperator": "GreaterThan",
        "triggerThreshold": 0,

        "suppressionDuration": "PT1H",
        "suppressionEnabled": false,

        "tactics": [ "LateralMovement" ],
        "techniques": [ "T1563.002" ],

        "entityMappings": [
          {
            "entityType": "Host",
            "fieldMappings": [
              { "identifier": "HostName", "columnName": "Computer" }
            ]
          },
          {
            "entityType": "Account",
            "fieldMappings": [
              { "identifier": "Name",     "columnName": "SubjectUserName" },
              { "identifier": "NTDomain", "columnName": "SubjectDomainName" }
            ]
          },
          {
            "entityType": "Process",
            "fieldMappings": [
              { "identifier": "CommandLine", "columnName": "CommandLine" }
            ]
          }
        ],

        "alertDetailsOverride": {
          "alertDisplayNameFormat": "RDP Hijack via tscon.exe on {{Computer}}",
          "alertDescriptionFormat": "tscon.exe was invoked on {{Computer}} by {{SubjectUserName}} with command: {{CommandLine}}"
        },

        "incidentConfiguration": {
          "createIncident": false,
          "groupingConfiguration": {
            "enabled": false,
            "reopenClosedIncident": false,
            "lookbackDuration": "PT5M",
            "matchingMethod": "AllEntities",
            "groupByEntities": [],
            "groupByAlertDetails": [],
            "groupByCustomDetails": []
          }
        }
      }
    }
  ]
}
